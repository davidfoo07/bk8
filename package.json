{
  "name": "courtedge",
  "private": true,
  "scripts": {
    "dev": "concurrently -n be,fe -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && ./venv/bin/uvicorn app.main:app --reload --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "test": "cd backend && ./venv/bin/python -m pytest tests/ -v",
    "test:quick": "cd backend && ./venv/bin/python -m pytest tests/ -x -q"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
